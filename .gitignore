# ══════════════════════════════════════════════════════════════════
# .gitignore — Fichiers à ne jamais commiter
# ══════════════════════════════════════════════════════════════════

# ── Secrets et clés d'API ──────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
*.key
*.pem
*.p12
*.pfx
*.secret
*_secret*
*secret*key*

# ── Dépendances ───────────────────────────────────────────────────
node_modules/
vendor/

# ── Build et compilation ──────────────────────────────────────────
dist/
build/
.next/
.nuxt/
out/
.output/
__pycache__/
*.pyc
*.pyo
.cache/

# ── Éditeurs et IDEs ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Fichiers temporaires ──────────────────────────────────────────
*.tmp
*.temp
.temp/
.tmp/
