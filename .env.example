# .env.example — Template public des variables d'environnement
#
# Ce fichier PEUT être commité sur Git. Il sert de référence pour savoir
# quelles variables sont nécessaires, sans exposer les vraies valeurs.
#
# Pour utiliser : copie ce fichier en .env et remplis les valeurs.

# ── Anthropic (Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Notion ─────────────────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Google ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── YouTube ────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Vercel ─────────────────────────────────────────────────────────────────
VERCEL_TOKEN=your_vercel_token_here

# ── GitHub ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
